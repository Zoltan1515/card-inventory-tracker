# Wicked Card Tracker Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: post selected Wicked Card Tracker inventory directly to PrimeLot.
# These are server-only Vercel env vars; never expose the service role key in client code.
PRIMELOT_SUPABASE_URL=https://xlljujognapvbdtvmrij.supabase.co
PRIMELOT_SUPABASE_SERVICE_ROLE_KEY=
PRIMELOT_SELLER_USER_ID=
PRIMELOT_SITE_URL=https://primelot.cards
# Shared secret used for PrimeLot <-> WCT server-to-server calls.
# WCT sends this to PrimeLot seller-status; PrimeLot sends this to WCT import/connection-status.
PRIMELOT_TO_WCT_IMPORT_SECRET=
# active posts live immediately; use draft if you want review before publishing.
PRIMELOT_POST_STATUS=active
